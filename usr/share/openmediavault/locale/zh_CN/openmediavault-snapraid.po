msgid "A config file for this array does not exist."
msgstr "此整列的配置文件不存在。"

msgid "A data drive cannot be a parity drive."
msgstr "数据盘不能做校验盘"

msgid ""
"Are you sure you want to force a full sync? This will recompute all parity "
"blocks from scratch and may take a very long time."
msgstr ""

msgid ""
"Are you sure you want to redirect this data drive to an empty directory in "
"the snapraid config? Apply settings afterwards, then run 'Force Empty Sync' "
"on the array."
msgstr ""

msgid ""
"Are you sure you want to restore this drive to its original mount path? "
"Apply settings afterwards to update the snapraid config."
msgstr ""

msgid ""
"Are you sure you want to run Force Empty Sync? Use this after setting a data"
" drive to an empty directory and applying settings. SnapRAID will update "
"parity to reflect the now-empty drive."
msgstr ""

